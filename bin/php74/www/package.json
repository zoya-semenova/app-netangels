{
  "name": "starter-b24ui-nuxt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:backend\" \"npm:back\" \"npm:frontend\" --trace-deprecation",
    "frontend": "nuxt dev --host 0.0.0.0",
    "patch": "node ./build-tools/patch-styles.mjs",
    "build": "npm run patch && concurrently -k -s first \"node ./server/index.mjs\"  \"nuxt generate&&node ./build-tools/process-build.mjs\"",
    "start": "npm run dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "back": "npx tsx ./server/index.ts",
    "backend": "set NODE_OPTIONS='--experiments-modules'  && nodemon  --watch ./server ./server/index.mjs --ext .js .ts"
  },
  "dependencies": {
    "@bitrix24/b24icons-vue": "latest",
    "@bitrix24/b24jssdk-nuxt": "^0.4.9",
    "@bitrix24/b24ui-nuxt": "^2.1.12",
    "axios": "^1.12.0",
    "fs.promises.exists": "1.1.3",
    "nuxt": "^4.0.0",
    "nuxt-auth-utils": "^0.5.20"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.4.1",
    "concurrently": "^7.0.0",
    "eslint": "^9.28.0",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "multer": "2.0.2",
    "nodemon": "3.1.10",
    "file-class": "^0.1.3",
    "get-port": "^6.1.2",
    "postcss": "8.5.6",
    "postcss-html": "1.3.0",
    "postcss-loader": "8.2.0",
    "postcss-preset-env": "^10.4.0",
    "typescript": "^5.8.3",
    "path": "^0.12.7",
    "@tsconfig/node16": "^16.1.5",
    "@types/express":"^4.17.14",
    "@types/multer": "^2.0.0",
    "@types/cors": "^2.8.19",
    "tsx": "4.20.6",
    "@typescript-eslint/parser":"^8.46.0",
    "@typescript-eslint/eslint-plugin":"^8.46.0",
    "@types/node": "^22.9.1"
  }
}
